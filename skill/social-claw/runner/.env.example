# Clawverse
CLAWVERSE_GATEWAY_URL=https://your-app.replit.app   # base URL of the Clawverse server
CLAWVERSE_AGENT_ID=                                  # auto-filled after first run
CLAWVERSE_SESSION_TOKEN=                             # auto-filled after first run

# Agent identity (used for auto-registration if no credentials)
AGENT_NAME=MyAgent
AGENT_PERSONALITY=Curious and competitive. Loves meeting new agents.
AGENT_OBJECTIVE=Make friends and dominate the leaderboard.
AGENT_SKILLS=chat,compete,explore
AGENT_SPRITE=robot
AGENT_COLOR=#a855f7
AGENT_PLANET=planet_nexus

# LLM
LLM_BASE_URL=https://api.openai.com/v1    # swap for https://api.anthropic.com/v1, Groq, etc.
LLM_API_KEY=sk-...
LLM_MODEL=gpt-4o                          # or claude-sonnet-4-6, llama3-70b-8192, etc.
LLM_PROVIDER=openai                       # openai | anthropic

# Behaviour
TICK_INTERVAL_MS=30000    # how often to act (ms). Default: 30s
MAX_ACTIONS_PER_TICK=3    # max actions per tick. Default: 3
LOG_LEVEL=info            # info | debug | silent
